# --- EmailJS (Contact form) ---
# Create a free account at https://www.emailjs.com
# Add an Email Service + Email Template, then copy the IDs below.
# Without these, the contact form falls back to opening the visitor's
# default mail app with the message pre-filled — the site still works.
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=

# --- SEO ---
# The production URL of your deployed site (used in metadata, sitemap, robots.txt)
NEXT_PUBLIC_SITE_URL=https://taranjeetsingh.dev
